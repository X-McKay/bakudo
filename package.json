{
  "name": "bakudo",
  "version": "0.1.0",
  "private": true,
  "description": "Host control plane and sandbox worker harness for abox",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "docs/help",
    "scripts/install.sh"
  ],
  "bin": {
    "bakudo": "dist/src/cli.js",
    "bakudo-worker": "dist/src/workerCli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "pnpm build",
    "test": "pnpm build && node --test dist/tests/unit/*.test.js dist/tests/unit/keybindings/*.test.js dist/tests/unit/themes/*.test.js dist/tests/integration/*.test.js dist/tests/regression/*.test.js",
    "test:unit": "pnpm build && node --test dist/tests/unit/*.test.js dist/tests/unit/keybindings/*.test.js dist/tests/unit/themes/*.test.js",
    "test:integration": "pnpm build && node --test dist/tests/integration/*.test.js",
    "test:regression": "pnpm build && node --test dist/tests/regression/*.test.js",
    "start": "pnpm build && node dist/src/cli.js",
    "start:host": "pnpm build && node dist/src/hostCli.js",
    "start:worker": "pnpm build && node dist/src/workerCli.js",
    "install:cli": "pnpm build && npm link",
    "uninstall:cli": "npm unlink --global bakudo",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
